config DRIVE
    bool "storage drives"
    default y
    help
      Enable storage drives?

menu "Filesystems"
    depends on DRIVE

config FAT12
    bool "fat12 filesystem"
    default y
    help
      Enable FAT12 filesystem?

endmenu

config CONSOLE
    bool "console support"
    default y
    help
      Enable console support?
