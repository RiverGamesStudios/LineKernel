menu "Storage"
    depends on DRIVE

config FLOPPY
    bool "floppy drive support"
    default y
    help
      Enable support for x86 Floppy Disk Controllers (FDC).

endmenu

config RDSEED
    bool "rdseed random number generator"
    help
      Enable RNG using RDSEED?

config RDRAND
    bool "rdrand random number generator"
    help
      Enable RNG using RDRAND?
