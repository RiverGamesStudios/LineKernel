menu "Console"
    depends on CONSOLE

config UART
    bool "uart console"
    default y
    help
      Enable UART console? This works similar to serial.

endmenu

choice
    prompt "Machine"
    default VIRT_MACHINE
    help
      Choose your machine.

config VIRT_MACHINE
    bool "virtual machine"

endchoice
